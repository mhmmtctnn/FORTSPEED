# ─── Database ────────────────────────────────────────────────────────────────
# REQUIRED: set a strong password before running docker-compose
POSTGRES_PASSWORD=change_me_in_production

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Authentication ───────────────────────────────────────────────────────────
# ITAI Hub integration (set to true only in enterprise deployments)
ITAI_MODE=false
ITAI_JWT_SECRET=

# API key for protecting admin endpoints (PUT /api/auth/config, webhook ingestion)
# Generate with: openssl rand -hex 32
LINKOPS_API_KEY=

# Allowed CORS origins (comma-separated). Leave empty for same-origin only (recommended for Nginx deployments).
# Example: CORS_ORIGIN=https://noc.example.com,https://admin.example.com
CORS_ORIGIN=

# ─── Map Tiles (Frontend) ─────────────────────────────────────────────────────
# Baked into the bundle at build time (VITE_ prefix required).
# Default: OpenFreeMap — free, no API key needed.
# Override with self-hosted tiles (martin, tileserver-gl) or MapTiler/Stadia if needed.
VITE_MAP_STYLE_LIGHT=https://tiles.openfreemap.org/styles/positron
VITE_MAP_STYLE_DARK=https://tiles.openfreemap.org/styles/dark

# ─── Auto-derived by docker-compose (do not change) ──────────────────────────
# DATABASE_URL and REDIS_URL are built from the values above inside docker-compose.yml
